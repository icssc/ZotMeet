DATABASE_URL=postgres://postgres:postgres@localhost:5432/zotmeet

# Public HTTPS origin for this deployment (emails, OAuth, Open Graph, sitemap).
# SST sets this automatically per stage; for local prod-like testing use:
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# iOS bundle ID from PWA Builder → Package for stores → iOS (update if yours differs).
NEXT_PUBLIC_IOS_BUNDLE_ID=com.zotmeet.app

# IARC certification code from https://www.globalratings.com/ (via a participating
# storefront questionnaire). Clears the PWABuilder IARC action item when set.
# PWA_IARC_RATING_ID=

# Register the service worker in non-production builds (e.g. when testing with PWABuilder
# against a preview URL). Leave unset in local dev unless you need SW debugging.
# NEXT_PUBLIC_ENABLE_SW=true
